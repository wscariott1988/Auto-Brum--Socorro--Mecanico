---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
	title: string;
    description?: string;
    ogTitle?: string;
    ogDescription?: string;
}

const { 
    title, 
    description = "Socorro Mecânico 24hrs especializado e rápido. Chegamos em 30 minutos na Grande Porto Alegre e Vale dos Sinos.",
    ogTitle = "Auto Brum | Socorro Mecânico 24hrs",
    ogDescription = "Carro Parado? Socorro Mecânico 24hrs Rápido na Estrada e Cidade. Atendimento 24h em Novo Hamburgo e região."
} = Astro.props;
const waUrl = "https://wa.me/5551998860146?text=PRECISO%20DE%20SOCORRO%20MEC%C3%82NICO%20URGENTE!%20Minha%20localiza%C3%A7%C3%A3o%20%C3%A9:";
---

<!doctype html>
<html lang="pt-br" class="dark scroll-smooth">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18084251132"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'AW-18084251132');

      // Snippet de conversão de ligações
      gtag('config', 'AW-18084251132/NBsMCNT18JocEPyLn69D', {
        'phone_conversion_number': '51998860146'
      });
    </script>

    <!-- Global conversion tracking script -->
    <script is:inline>
    function gtag_report_conversion(url, sendTo = 'AW-18084251132/dubkCIGV7ZocEPyLn69D') {
      console.log('gtag_report_conversion called with url:', url, 'send_to:', sendTo);
      var callback = function () {
        if (typeof(url) != 'undefined') {
          window.location = url;
        }
      };
      gtag('event', 'conversion', {
          'send_to': sendTo,
          'value': 1.0,
          'currency': 'BRL',
          'event_callback': callback
      });
      return false;
    }
    </script>

    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Open Graph / WhatsApp Preview -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.mecanicaautobrum.com.br" />
    <meta property="og:image" content="/background.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800;900&display=swap" rel="stylesheet" />

    <!-- Performance: Preload LCP Background Image -->
    <link rel="preload" as="image" href="/background.webp" media="(max-width: 767px)" fetchpriority="high" />
    <link rel="preload" as="image" href="/background.desktop.webp" media="(min-width: 768px)" fetchpriority="high" />
</head>
<body class="bg-black text-on-surface font-body antialiased selection:bg-brand-red selection:text-white">

    <!-- Header: Otimizado sem backdrop-blur para CPU mobile -->
    <header class="absolute top-0 w-full z-[100] bg-black flex justify-center md:justify-between items-center px-6 h-12 md:h-20 border-b border-white/5">
        <!-- Logo / Nome -->
        <span class="text-xl md:text-2xl font-black text-white tracking-tight uppercase after:content-[''] after:block after:w-[40%] after:h-[2px] after:bg-brand-yellow after:mx-auto md:after:mx-0 after:mt-1 whitespace-nowrap drop-shadow-md">Mecânica Auto Brum</span>
        <!-- Telefone - apenas Desktop -->
        <a href={waUrl} target="_blank" rel="noopener noreferrer" 
           onclick={`return gtag_report_conversion('${waUrl}')`}
           class="hidden md:flex items-center gap-2 text-white font-bold text-[15px] hover:text-[#25D366] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 1.891.524 3.662 1.435 5.176L2 22l4.957-1.396C8.36 21.493 10.106 22 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18c-1.74 0-3.327-.47-4.686-1.28l-.337-.202-2.935.827.842-2.868-.222-.352C3.84 14.802 3.32 13.435 3.32 12c0-4.787 3.893-8.68 8.68-8.68 4.787 0 8.68 3.893 8.68 8.68S16.787 20 12 20zm4.84-5.368c-.266-.134-1.574-.776-1.818-.865-.243-.09-.42-.134-.597.134-.176.268-.685.865-.84 1.044-.154.178-.309.201-.575.067-.266-.134-1.124-.413-2.14-1.319-.79-.705-1.325-1.576-1.48-1.844-.155-.268-.016-.413.118-.546.12-.12.266-.312.4-.468.133-.156.177-.268.266-.446.088-.178.044-.334-.022-.468-.066-.134-.597-1.442-.818-1.977-.215-.522-.43-.45-.597-.458h-.508c-.176 0-.465.067-.708.334-.243.268-.93.914-.93 2.23 0 1.316.953 2.585 1.085 2.764.133.179 1.876 2.855 4.545 4.005.635.273 1.13.437 1.516.56.638.203 1.22.174 1.678.106.51-.076 1.574-.643 1.796-1.265.223-.623.223-1.159.155-1.265-.067-.107-.243-.178-.508-.312z"/></svg>
            (51) 99886-0146
        </a>
    </header>

    <main class="w-full relative z-0">
        <slot />
    </main>

    <footer class="w-full relative z-0 text-center py-6 pb-24 md:pb-6">
        <a href="https://wa.me/5551999402810?text=Vi%20a%20p%C3%A1gina%20da%20Mec%C3%A2nica%20Auto%20Brum%20e%20gostei%2C%20gostaria%20de%20um%20or%C3%A7amento%20para%20criar%20minha%20p%C3%A1gina." target="_blank" rel="noopener noreferrer" class="text-[10px] text-zinc-600 hover:text-white transition-colors select-none inline-block">
            Desenvolvido por Grupo WS
        </a>
    </footer>

    <!-- Sticky Mobile Footer: APENAS WhatsApp (Ligar já está na Hero) -->
    <nav class="fixed bottom-4 left-4 right-4 z-[120] flex md:hidden">
        <a href={waUrl} target="_blank" rel="noopener noreferrer"
           onclick={`return gtag_report_conversion('${waUrl}')`}
           class="w-full flex items-center justify-center gap-3
                  bg-[#25D366] text-white
                  h-14 rounded-2xl border border-[#20b558]/60
                  font-black uppercase tracking-widest text-[15px]
                  shadow-[0_10px_30px_rgba(37,211,102,0.35)]
                  active:scale-95 transition-all duration-200 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 border-none" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 1.891.524 3.662 1.435 5.176L2 22l4.957-1.396C8.36 21.493 10.106 22 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18c-1.74 0-3.327-.47-4.686-1.28l-.337-.202-2.935.827.842-2.868-.222-.352C3.84 14.802 3.32 13.435 3.32 12c0-4.787 3.893-8.68 8.68-8.68 4.787 0 8.68 3.893 8.68 8.68S16.787 20 12 20zm4.84-5.368c-.266-.134-1.574-.776-1.818-.865-.243-.09-.42-.134-.597.134-.176.268-.685.865-.84 1.044-.154.178-.309.201-.575.067-.266-.134-1.124-.413-2.14-1.319-.79-.705-1.325-1.576-1.48-1.844-.155-.268-.016-.413.118-.546.12-.12.266-.312.4-.468.133-.156.177-.268.266-.446.088-.178.044-.334-.022-.468-.066-.134-.597-1.442-.818-1.977-.215-.522-.43-.45-.597-.458h-.508c-.176 0-.465.067-.708.334-.243.268-.93.914-.93 2.23 0 1.316.953 2.585 1.085 2.764.133.179 1.876 2.855 4.545 4.005.635.273 1.13.437 1.516.56.638.203 1.22.174 1.678.106.51-.076 1.574-.643 1.796-1.265.223-.623.223-1.159.155-1.265-.067-.107-.243-.178-.508-.312z"/></svg>
            Chamar Socorro no WhatsApp
        </a>
    </nav>


    <!-- Botão Flutuante WhatsApp APENAS Desktop -->
    <a href={waUrl} target="_blank" rel="noopener noreferrer"
       onclick={`return gtag_report_conversion('${waUrl}')`}
       class="hidden md:flex fixed bottom-8 right-8 z-[120] w-16 h-16 bg-[#25D366] rounded-full items-center justify-center shadow-[0_8px_30px_rgba(37,211,102,0.5)] hover:scale-110 hover:shadow-[0_12px_40px_rgba(37,211,102,0.7)] transition-all duration-300"
       title="Falar no WhatsApp">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 1.891.524 3.662 1.435 5.176L2 22l4.957-1.396C8.36 21.493 10.106 22 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18c-1.74 0-3.327-.47-4.686-1.28l-.337-.202-2.935.827.842-2.868-.222-.352C3.84 14.802 3.32 13.435 3.32 12c0-4.787 3.893-8.68 8.68-8.68 4.787 0 8.68 3.893 8.68 8.68S16.787 20 12 20zm4.84-5.368c-.266-.134-1.574-.776-1.818-.865-.243-.09-.42-.134-.597.134-.176.268-.685.865-.84 1.044-.154.178-.309.201-.575.067-.266-.134-1.124-.413-2.14-1.319-.79-.705-1.325-1.576-1.48-1.844-.155-.268-.016-.413.118-.546.12-.12.266-.312.4-.468.133-.156.177-.268.266-.446.088-.178.044-.334-.022-.468-.066-.134-.597-1.442-.818-1.977-.215-.522-.43-.45-.597-.458h-.508c-.176 0-.465.067-.708.334-.243.268-.93.914-.93 2.23 0 1.316.953 2.585 1.085 2.764.133.179 1.876 2.855 4.545 4.005.635.273 1.13.437 1.516.56.638.203 1.22.174 1.678.106.51-.076 1.574-.643 1.796-1.265.223-.623.223-1.159.155-1.265-.067-.107-.243-.178-.508-.312z"/></svg>
    </a>

</body>
</html>
