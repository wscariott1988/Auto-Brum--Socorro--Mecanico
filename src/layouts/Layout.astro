---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
const waUrl = "https://wa.me/5551996688568?text=PRECISO%20DE%20SOCORRO%20MEC%C3%82NICO%20URGENTE!%20Minha%20localiza%C3%A7%C3%A3o%20%C3%A9:";
---

<!doctype html>
<html lang="pt-br" class="dark scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content="Socorro Mecânico 24h especializado e rápido. Chegamos em 30 minutos na Grande Porto Alegre e Vale dos Sinos." />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
</head>
<body class="bg-black text-on-surface font-body antialiased selection:bg-brand-red selection:text-white">

    <!-- Header: Mobile = nome centrado | Desktop = nome + telefone -->
    <header class="absolute top-0 w-full z-[100] bg-black/80 backdrop-blur-[8px] flex justify-center md:justify-between items-center px-6 h-12 md:h-20 border-b border-white/5">
        <!-- Logo / Nome -->
        <span class="text-xl md:text-2xl font-black text-white tracking-tight uppercase after:content-[''] after:block after:w-[40%] after:h-[2px] after:bg-brand-yellow after:mx-auto md:after:mx-0 after:mt-1 whitespace-nowrap drop-shadow-md">Mecânica Auto Brum</span>
        <!-- Telefone - apenas Desktop -->
        <a href={waUrl} target="_blank" rel="noopener noreferrer" class="hidden md:flex items-center gap-2 text-white font-bold text-[15px] hover:text-[#25D366] transition-colors">
            <span class="material-symbols-outlined text-[#25D366] text-[20px]">chat</span>
            (51) 99668-8568
        </a>
    </header>

    <main class="w-full relative z-0">
        <slot />
    </main>

    <footer class="w-full relative z-0 text-center py-6 pb-24 md:pb-6">
        <a href="https://wa.me/5551999402810?text=Vi%20a%20p%C3%A1gina%20da%20Mec%C3%A2nica%20Auto%20Brum%20e%20gostei%2C%20gostaria%20de%20um%20or%C3%A7amento%20para%20criar%20minha%20p%C3%A1gina." target="_blank" rel="noopener noreferrer" class="text-[10px] text-zinc-600 hover:text-white transition-colors select-none inline-block">
            desenvolvido por Grupo WS
        </a>
    </footer>

    <!-- Sticky Mobile Footer: APENAS WhatsApp (Ligar já está na Hero) -->
    <nav class="fixed bottom-4 left-4 right-4 z-[120] flex md:hidden">
        <a href={waUrl} target="_blank" rel="noopener noreferrer"
           class="w-full flex items-center justify-center gap-3
                  bg-[#25D366]/90 backdrop-blur-sm text-white
                  h-14 rounded-2xl border border-[#20b558]/60
                  font-black uppercase tracking-widest text-[16px]
                  shadow-[0_10px_30px_rgba(37,211,102,0.35)]
                  active:scale-95 transition-all duration-200">
            <span class="material-symbols-outlined text-[22px]" style="font-variation-settings: 'FILL' 1;">chat</span>
            Chamar Socorro no WhatsApp
        </a>
    </nav>


    <!-- Botão Flutuante WhatsApp APENAS Desktop -->
    <a href={waUrl} target="_blank" rel="noopener noreferrer"
       class="hidden md:flex fixed bottom-8 right-8 z-[120] w-16 h-16 bg-[#25D366] rounded-full items-center justify-center shadow-[0_8px_30px_rgba(37,211,102,0.5)] hover:scale-110 hover:shadow-[0_12px_40px_rgba(37,211,102,0.7)] transition-all duration-300 animate-pulse-soft"
       title="Falar no WhatsApp">
        <span class="material-symbols-outlined text-white text-[32px]">chat</span>
    </a>

</body>
</html>
