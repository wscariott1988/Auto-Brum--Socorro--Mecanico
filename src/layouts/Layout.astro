---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
	title: string;
    description?: string;
    ogTitle?: string;
    ogDescription?: string;
}

const { 
    title, 
    description = "Socorro Mecânico 24hrs especializado e rápido. Chegamos em 30 minutos na Grande Porto Alegre e Vale dos Sinos.",
    ogTitle = "Auto Brum | Socorro Mecânico 24hrs",
    ogDescription = "Carro Parado? Socorro Mecânico 24hrs Rápido na Estrada e Cidade. Atendimento 24h em Novo Hamburgo e região."
} = Astro.props;
const waUrl = "https://wa.me/5551998860146?text=PRECISO%20DE%20SOCORRO%20MEC%C3%82NICO%20URGENTE!%20Minha%20localiza%C3%A7%C3%A3o%20%C3%A9:";
---

<!doctype html>
<html lang="pt-br" class="dark scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.mecanicaautobrum.com.br" />
    <meta property="og:image" content="/background.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Google Fonts: CSS inline (apenas latin para nao bloquear) -->
    <style>
    @font-face{font-family:'Inter';font-style:normal;font-weight:400;font-display:swap;src:local('Inter Regular'),local('Inter'),url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
    @font-face{font-family:'Inter';font-style:normal;font-weight:700;font-display:swap;src:local('Inter Bold'),url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
    @font-face{font-family:'Inter';font-style:normal;font-weight:800;font-display:swap;src:local('Inter ExtraBold'),url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
    @font-face{font-family:'Inter';font-style:normal;font-weight:900;font-display:swap;src:local('Inter Black'),url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
    </style>
    <link rel="preload" as="font" href="https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2" crossorigin="anonymous" fetchpriority="high">

    <!-- Performance: Preload LCP Background Image com dimensoes -->
    <link rel="preload" as="image" href="/background.webp" media="(max-width: 767px)" fetchpriority="high" imagesrcset="/background.webp 430w" imagesizes="100vw" />
    <link rel="preload" as="image" href="/background.desktop.webp" media="(min-width: 768px)" fetchpriority="high" />

    <!-- Pulse animation inline (usado no CTA hero) -->
    <style>@keyframes pulse-soft{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.05);opacity:.8}}.animate-pulse-soft{animation:pulse-soft 2s cubic-bezier(.4,0,.6,1) infinite}</style>

    <!-- FAQ.css carregado sem bloqueio -->
    <link rel="stylesheet" href="/_astro/FAQ.Bflo2vrC.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="/_astro/FAQ.Bflo2vrC.css" /></noscript>

    <!-- Google Tag Manager (deferido - carrega apos interacao) -->
    <script is:inline>
    const gtmLoaded = false;
    function loadGTM() {
      if (window.gtmLoaded) return;
      window.gtmLoaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=AW-18084251132';
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', 'AW-18084251132');
      gtag('config', 'AW-18084251132/NBsMCNT18JocEPyLn69D', { 'phone_conversion_number': '51998860146' });
    }
    function gtag_report_conversion(url, sendTo) {
      if (!sendTo) sendTo = 'AW-18084251132/dubkCIGV7ZocEPyLn69D';
      loadGTM();
      var callback = function () {
        if (typeof(url) != 'undefined') window.location = url;
      };
      if (window.gtag) {
        window.gtag('event', 'conversion', {
            'send_to': sendTo,
            'value': 1.0,
            'currency': 'BRL',
            'event_callback': callback
        });
      } else {
        if (typeof(url) != 'undefined') window.location = url;
      }
      return false;
    }
    window.addEventListener('scroll', loadGTM, { once: true });
    window.addEventListener('touchstart', loadGTM, { once: true });
    window.addEventListener('mousemove', loadGTM, { once: true });
    </script>

    <!-- Microsoft Clarity (deferido) -->
    <script is:inline>
    window.addEventListener('scroll', function(){
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window, document, "clarity", "script", "xmj9nxdg65");
    }, { once: true });
    window.addEventListener('touchstart', function(){
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window, document, "clarity", "script", "xmj9nxdg65");
    }, { once: true });
    </script>
</head>
<body class="bg-black text-on-surface font-body antialiased selection:bg-brand-red selection:text-white">

    <!-- Header: Otimizado sem backdrop-blur para CPU mobile -->
    <header class="absolute top-0 w-full z-[100] bg-black flex justify-center md:justify-between items-center px-6 h-12 md:h-20 border-b border-white/5">
        <!-- Logo / Nome -->
        <span class="text-xl md:text-2xl font-black text-white tracking-tight uppercase after:content-[''] after:block after:w-[40%] after:h-[2px] after:bg-brand-yellow after:mx-auto md:after:mx-0 after:mt-1 whitespace-nowrap drop-shadow-md">Mecânica Auto Brum</span>
        <!-- Telefone - apenas Desktop -->
        <a href={waUrl} target="_blank" rel="noopener noreferrer" 
           onclick={`return gtag_report_conversion('${waUrl}')`}
           class="hidden md:flex items-center gap-2 text-white font-bold text-[15px] hover:text-[#25D366] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 1.891.524 3.662 1.435 5.176L2 22l4.957-1.396C8.36 21.493 10.106 22 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18c-1.74 0-3.327-.47-4.686-1.28l-.337-.202-2.935.827.842-2.868-.222-.352C3.84 14.802 3.32 13.435 3.32 12c0-4.787 3.893-8.68 8.68-8.68 4.787 0 8.68 3.893 8.68 8.68S16.787 20 12 20zm4.84-5.368c-.266-.134-1.574-.776-1.818-.865-.243-.09-.42-.134-.597.134-.176.268-.685.865-.84 1.044-.154.178-.309.201-.575.067-.266-.134-1.124-.413-2.14-1.319-.79-.705-1.325-1.576-1.48-1.844-.155-.268-.016-.413.118-.546.12-.12.266-.312.4-.468.133-.156.177-.268.266-.446.088-.178.044-.334-.022-.468-.066-.134-.597-1.442-.818-1.977-.215-.522-.43-.45-.597-.458h-.508c-.176 0-.465.067-.708.334-.243.268-.93.914-.93 2.23 0 1.316.953 2.585 1.085 2.764.133.179 1.876 2.855 4.545 4.005.635.273 1.13.437 1.516.56.638.203 1.22.174 1.678.106.51-.076 1.574-.643 1.796-1.265.223-.623.223-1.159.155-1.265-.067-.107-.243-.178-.508-.312z"/></svg>
            (51) 99886-0146
        </a>
    </header>

    <main class="w-full relative z-0">
        <slot />
    </main>

    <footer class="w-full relative z-0 text-center py-6 pb-20 md:pb-6">
        <a href="https://wa.me/5551999402810?text=Vi%20a%20p%C3%A1gina%20da%20Mec%C3%A2nica%20Auto%20Brum%20e%20gostei%2C%20gostaria%20de%20um%20or%C3%A7amento%20para%20criar%20minha%20p%C3%A1gina." target="_blank" rel="noopener noreferrer" class="text-[10px] text-zinc-600 hover:text-white transition-colors select-none inline-block">
            Desenvolvido por Grupo WS
        </a>
    </footer>

    <!-- Botão Flutuante WhatsApp (Mobile + Desktop) -->
    <a href={waUrl} target="_blank" rel="noopener noreferrer"
       onclick={`return gtag_report_conversion('${waUrl}')`}
       class="flex fixed bottom-6 right-6 z-[120] w-14 h-14 md:w-16 md:h-16 bg-[#25D366] rounded-full items-center justify-center shadow-[0_8px_30px_rgba(37,211,102,0.5)] hover:scale-110 hover:shadow-[0_12px_40px_rgba(37,211,102,0.7)] active:scale-95 transition-all duration-300"
       title="Falar no WhatsApp">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 md:w-8 md:h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 1.891.524 3.662 1.435 5.176L2 22l4.957-1.396C8.36 21.493 10.106 22 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18c-1.74 0-3.327-.47-4.686-1.28l-.337-.202-2.935.827.842-2.868-.222-.352C3.84 14.802 3.32 13.435 3.32 12c0-4.787 3.893-8.68 8.68-8.68 4.787 0 8.68 3.893 8.68 8.68S16.787 20 12 20zm4.84-5.368c-.266-.134-1.574-.776-1.818-.865-.243-.09-.42-.134-.597.134-.176.268-.685.865-.84 1.044-.154.178-.309.201-.575.067-.266-.134-1.124-.413-2.14-1.319-.79-.705-1.325-1.576-1.48-1.844-.155-.268-.016-.413.118-.546.12-.12.266-.312.4-.468.133-.156.177-.268.266-.446.088-.178.044-.334-.022-.468-.066-.134-.597-1.442-.818-1.977-.215-.522-.43-.45-.597-.458h-.508c-.176 0-.465.067-.708.334-.243.268-.93.914-.93 2.23 0 1.316.953 2.585 1.085 2.764.133.179 1.876 2.855 4.545 4.005.635.273 1.13.437 1.516.56.638.203 1.22.174 1.678.106.51-.076 1.574-.643 1.796-1.265.223-.623.223-1.159.155-1.265-.067-.107-.243-.178-.508-.312z"/></svg>
    </a>

</body>
</html>
