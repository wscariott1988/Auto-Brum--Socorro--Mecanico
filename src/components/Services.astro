---
interface Props {
  customServices?: {
    icon: string;
    title: string;
    desc: string;
    ctaMobile: string;
    ctaDesktop: string;
    waMsg: string;
  }[];
}

const { customServices } = Astro.props;

const waBase = "https://wa.me/5551998860146?text=";
const defaultServices = [
  {
    icon: "handyman",
    title: "Pane Mecânica",
    desc: "Diagnóstico e reparo rápido no local.",
    ctaMobile: "SOLICITAR MECÂNICO AGORA",
    ctaDesktop: "SOLICITAR VIA WHATSAPP",
    waMsg: "PRECISO%20DE%20SOCORRO%20MEC%C3%82NICO%20URGENTE!%20Minha%20localiza%C3%A7%C3%A3o%20%C3%A9:"
  },
  {
    icon: "electric_bolt",
    title: "Troca de Bateria",
    desc: "Substituição imediata com garantia.",
    ctaMobile: "RECARREGAR MINHA BATERIA",
    ctaDesktop: "SOLICITAR VIA WHATSAPP",
    waMsg: "PRECISO%20DE%20SOCORRO%20DE%20BATERIA!%20Minha%20localiza%C3%A7%C3%A3o%20%C3%A9:"
  },
  {
    icon: "local_gas_station",
    title: "Pane Seca",
    desc: "Entrega de combustível na emergência.",
    ctaMobile: "PRECISO DE COMBUSTÍVEL",
    ctaDesktop: "SOLICITAR VIA WHATSAPP",
    waMsg: "ESTOU%20COM%20PANE%20SECA!%20Minha%20localiza%C3%A7%C3%A3o%20%C3%A9:"
  },
  {
    icon: "device_thermostat",
    title: "Superaquecimento",
    desc: "Resfriamento e diagnósticos no motor.",
    ctaMobile: "SOCORRO PARA O MOTOR",
    ctaDesktop: "SOLICITAR VIA WHATSAPP",
    waMsg: "PRECISO%20DE%20SOCORRO%20T%C3%89RMICO!%20O%20carro%20superaqueceu.%20Minha%20localiza%C3%A7%C3%A3o%20%C3%A9:"
  }
];

const services = customServices || defaultServices;
---
<section class="max-w-7xl mx-auto px-6 md:px-12 pt-8 pb-20 relative z-10">
    <div class="flex flex-col mb-10">
        <h2 class="text-3xl font-black uppercase tracking-tight mb-2 text-white">Nossos Serviços</h2>
        <div class="h-1 w-20 bg-brand-yellow"></div>
    </div>
    
    <!-- Mobile: 1 col | Tablet: 2 col | Desktop: 4 col -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((s) => (
            <div class="bg-[#1f1f1f] border-l-4 border-brand-yellow p-6 flex flex-col rounded-r shadow-lg hover:shadow-[0_4px_20px_rgba(237,192,1,0.12)] transition-all h-full">
                <div class="flex flex-col items-center sm:items-start text-center sm:text-left flex-grow">
                    {s.icon === "handyman" && <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-brand-yellow mb-4" fill="currentColor" viewBox="0 -960 960 960"><path d="M784-80 614-250q-11 5-22.5 7.5T568-240q-63 0-107.5-44.5T416-392q0-10 2-21t5-21L80-776l104-104 342 342q10-3 21-5t21-2q63 0 107.5 44.5T720-392q0 12-2.5 23.5T710-346l170 170-96 96ZM496-392q0 33 23.5 56.5T576-312q33 0 56.5-23.5T656-392q0-33-23.5-56.5T576-472q-33 0-56.5 23.5T496-392Z"/></svg>}
                    {s.icon === "electric_bolt" && <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-brand-yellow mb-4" fill="currentColor" viewBox="0 -960 960 960"><path d="M320-80v-400H160l320-400v400h160L320-80Z"/></svg>}
                    {s.icon === "local_gas_station" && <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-brand-yellow mb-4" fill="currentColor" viewBox="0 -960 960 960"><path d="M160-120v-560q0-33 23.5-56.5T240-760h240q33 0 56.5 23.5T560-680v200h40v-120q0-17 11.5-28.5T640-640q17 0 28.5 11.5T680-600v200q0 33 23.5 56.5T760-320h40v200h-80l-40-100-40 100H160Zm80-80h240v-80q0-33-23.5-56.5T400-360H240v160Zm0-240h240v-240H240v240Zm440 240v-80h40q17 0 28.5-11.5T760-200q17 0 28.5-11.5T800-240v-40h-80v40h-40l40-200h-80v200h-40v80h80ZM240-200v-160 160Z"/></svg>}
                    {s.icon === "device_thermostat" && <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-brand-yellow mb-4" fill="currentColor" viewBox="0 -960 960 960"><path d="M480-120q-75 0-127.5-52.5T300-300q0-46 22-86.5t61-64.5l3-269q0-39 27-64.5t67-25.5q39 0 66.5 25.5T573-720l3 269q39 24 61.5 64.5T660-300q0 75-52.5 127.5T480-120Zm0-80q42 0 71-29t29-71q0-30-15.5-55T522-393l-42-30v-297q0-5 3.5-8.5T492-732q5 0 8.5 3.5t3.5 8.5v40h56v-40q0-28-19.5-47.5T493-787q-29 0-48.5 19.5T425-720v297l-41 30q-26 19-42.5 46.5T325-291q0 42 30.5 71.5T426-191q5 0 8.5-3.5t3.5-8.5v-18q0-8 6.5-13.5t14.5-5.5q8 0 14.5 5.5t6.5 13.5v18q0 5 3.5 8.5t8.5 3.5Zm0-100Z"/></svg>}
                    <h3 class="text-xl font-bold uppercase mb-2 text-white">{s.title}</h3>
                    <p class="text-[15px] leading-relaxed text-gray-400 mb-6">{s.desc}</p>
                </div>
                <!-- Mobile CTA (red) -->
                <a href={`${waBase}${s.waMsg}`} target="_blank" rel="noopener noreferrer"
                   onclick={`return gtag_report_conversion('${waBase}${s.waMsg}')`}
                   class="md:hidden w-full flex items-center justify-center bg-[#D32732] text-white min-h-[48px] px-3 py-3 text-[12px] font-bold uppercase tracking-wider hover:brightness-110 shadow-md active:scale-95 transition-all rounded-xl text-center mt-auto">
                    {s.ctaMobile}
                </a>
                <!-- Desktop CTA (green/WhatsApp) -->
                <a href={`${waBase}${s.waMsg}`} target="_blank" rel="noopener noreferrer"
                   onclick={`return gtag_report_conversion('${waBase}${s.waMsg}')`}
                   class="hidden md:flex w-full items-center justify-center bg-[#25D366] text-white min-h-[48px] px-3 py-3 text-[13px] font-bold uppercase tracking-wider hover:brightness-110 shadow-md active:scale-95 transition-all rounded-xl text-center mt-auto gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 1.891.524 3.662 1.435 5.176L2 22l4.957-1.396C8.36 21.493 10.106 22 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18c-1.74 0-3.327-.47-4.686-1.28l-.337-.202-2.935.827.842-2.868-.222-.352C3.84 14.802 3.32 13.435 3.32 12c0-4.787 3.893-8.68 8.68-8.68 4.787 0 8.68 3.893 8.68 8.68S16.787 20 12 20zm4.84-5.368c-.266-.134-1.574-.776-1.818-.865-.243-.09-.42-.134-.597.134-.176.268-.685.865-.84 1.044-.154.178-.309.201-.575.067-.266-.134-1.124-.413-2.14-1.319-.79-.705-1.325-1.576-1.48-1.844-.155-.268-.016-.413.118-.546.12-.12.266-.312.4-.468.133-.156.177-.268.266-.446.088-.178.044-.334-.022-.468-.066-.134-.597-1.442-.818-1.977-.215-.522-.43-.45-.597-.458h-.508c-.176 0-.465.067-.708.334-.243.268-.93.914-.93 2.23 0 1.316.953 2.585 1.085 2.764.133.179 1.876 2.855 4.545 4.005.635.273 1.13.437 1.516.56.638.203 1.22.174 1.678.106.51-.076 1.574-.643 1.796-1.265.223-.623.223-1.159.155-1.265-.067-.107-.243-.178-.508-.312z"/></svg>
                    {s.ctaDesktop}
                </a>
            </div>
        ))}
    </div>
</section>
