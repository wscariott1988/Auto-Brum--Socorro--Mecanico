---
interface Props {
    cityTag?: string;
}

const {
    cityTag = "Novo Hamburgo, São Leopoldo, Campo Bom e Vale dos Sinos",
} = Astro.props;

const waUrl = "https://wa.me/5551998860146?text=PRECISO%20DE%20SOCORRO%20MEC%C3%82NICO%20URGENTE!%20Minha%20localiza%C3%A7%C3%A3o%20%C3%A9:";
---

<section class="relative min-h-[100dvh] flex flex-col overflow-hidden px-5 md:px-20">

    <!-- Fundo otimizado para LCP -->
    <div class="absolute inset-0 z-0 overflow-hidden">
        <picture>
            <source srcset="/background.desktop.webp" media="(min-width: 768px)" width="1920" height="1080" />
            <img 
                src="/background.webp" 
                alt="" 
                class="absolute inset-0 w-full h-full object-cover object-center"
                width="430"
                height="932"
                fetchpriority="high"
                loading="eager"
                decoding="async"
            />
        </picture>
        <div class="absolute inset-0 bg-black/90"></div>
    </div>

    <!-- ==========================================
         MOBILE LAYOUT - Otimizado para CTA acima da dobra
         ========================================== -->
    <div class="md:hidden relative z-10 flex flex-col items-center text-center
