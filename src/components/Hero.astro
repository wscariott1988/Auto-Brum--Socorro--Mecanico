        </div>

        <!-- Título pequeno: urgência -->
        <h2 class="text-[1rem] font-bold uppercase text-white/80 tracking-wider leading-snug">
            Carro Parou Agora?
        </h2>

        <!-- Título principal - AGORA LINKÁVEL -->
        <a href={waUrl} target="_blank" rel="noopener noreferrer"
           onclick={`return gtag_report_conversion('${waUrl}')`}
           class="block">
