---
// src/components/TrustBar.astro
---
<section class="bg-[#161616] border-b border-white/5 relative z-20">
    <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col md:flex-row items-center divide-y md:divide-y-0 md:divide-x divide-white/10">

        <!-- Item 1: Mecânicos Certificados -->
        <div class="flex flex-col md:flex-row items-center justify-center gap-3 md:gap-4 w-full md:w-1/2 py-4 md:py-5">
            <span class="material-symbols-outlined text-brand-yellow text-3xl md:text-4xl" data-icon="verified_user">verified_user</span>
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <span class="uppercase tracking-wider font-bold text-sm md:text-base text-white">Mecânicos Certificados</span>
                <span class="text-xs text-gray-400 font-medium mt-0.5 hidden md:block">Profissionais com formação técnica</span>
            </div>
        </div>

        <!-- Item 2: Atendimento 24h -->
        <div class="flex flex-col md:flex-row items-center justify-center gap-3 md:gap-4 w-full md:w-1/2 py-4 md:py-5">
            <span class="material-symbols-outlined text-brand-yellow text-3xl md:text-4xl" data-icon="schedule">schedule</span>
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <span class="uppercase tracking-wider font-bold text-sm md:text-base text-white">Atendimento 24h</span>
                <span class="text-xs text-gray-400 font-medium mt-0.5 hidden md:block">Disponível todos os dias, sem exceção</span>
            </div>
        </div>

    </div>
</section>
