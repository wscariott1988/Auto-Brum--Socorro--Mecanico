---
---
<section class="w-full bg-black py-16 md:py-24 relative z-10">
    <div class="max-w-3xl mx-auto px-6 flex flex-col items-center">

        <!-- Imagem com overlay do título -->
        <div class="relative w-full flex justify-center">
            <div class="absolute top-4 left-4 md:top-5 md:left-5 bg-black/70 backdrop-blur-sm rounded-lg px-3 py-2 z-10">
                <span class="text-white text-[11px] md:text-xs font-black uppercase tracking-widest">Atendimento Real</span>
            </div>
            <img
                src="/foto-real.webp"
                alt="Mecânico realizando atendimento em veículo na região de Novo Hamburgo"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                width="800"
                height="600"
                class="w-full max-w-[800px] rounded-xl shadow-lg shadow-black/20 object-cover"
            />
        </div>

        <!-- Texto descritivo -->
        <p class="text-[14px] md:text-[15px] text-gray-400 text-center max-w-lg mx-auto mt-6 leading-snug font-medium">
            Atendimento realizado por mecânicos experientes diretamente no local da ocorrência.
        </p>

        <!-- 4 indicadores -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-3 mt-8">
            <div class="flex items-center gap-2">
                <span class="text-brand-yellow text-base font-black leading-none">✔</span>
                <span class="text-[13px] font-semibold text-gray-300">Atendimento no local</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-brand-yellow text-base font-black leading-none">✔</span>
                <span class="text-[13px] font-semibold text-gray-300">Mecânicos certificados</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-brand-yellow text-base font-black leading-none">✔</span>
                <span class="text-[13px] font-semibold text-gray-300">Atendimento 24 horas</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-brand-yellow text-base font-black leading-none">✔</span>
                <span class="text-[13px] font-semibold text-gray-300">Novo Hamburgo e região</span>
            </div>
        </div>

    </div>
</section>
