// Sort reviews so longest comes first
reviews.sort((a, b) => b.text.length - a.text.length);
---
<section class="bg-[#0e0e0e] py-16 relative z-10 border-y border-white/5 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 mb-12 flex flex-col items-center">
        <h2 class="text-2xl font-black uppercase text-center text-white mb-4">Depoimentos Reais</h2>
        <div class="flex items-center gap-2 bg-white/5 py-1.5 px-4 rounded-full border border-white/10">
            <img src="/google-verified.webp" alt="Google Verified" class="h-6 w-auto object-contain" width="100" height="24" loading="lazy" />
            <span class="text-sm font-bold text-white tracking-widest">⭐⭐⭐⭐⭐ 5.0</span>
        </div>
    </div>

    <!-- Carousel Container -->
    <div 
        id="testimonial-carousel"
        class="flex overflow-x-auto gap-6 select-none pl-6 md:pl-0 cursor-grab active:cursor-grabbing no-scrollbar"
        style="scrollbar-width: none; -ms-overflow-style: none;"
    >
        <!-- Scroll Track -->
        <div id="testimonial-track" class="flex flex-shrink-0 gap-6">
            {reviews.map((review) => (
                <div class="bg-[#1b1b1b] border border-brand-yellow p-6 rounded shadow-xl flex flex-col w-[300px] md:w-[350px] flex-shrink-0 whitespace-normal snap-center">
                    <div class="flex text-white mb-4 text-sm gap-1">
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                    </div>
                    <p class="text-[#e2e2e2] mb-6 italic leading-relaxed flex-1">"{review.text}"</p>
                    <div class="flex items-center mt-auto border-t border-white/10 pt-4">
                        <span class="text-sm font-bold uppercase tracking-widest text-brand-yellow">{review.name}</span>
                    </div>
                </div>
            ))}
            
            <!-- Clone for infinite loop -->
            {reviews.map((review) => (
                <div class="bg-[#1b1b1b] border border-brand-yellow p-6 rounded shadow-xl flex flex-col w-[300px] md:w-[350px] flex-shrink-0 whitespace-normal snap-center" aria-hidden="true">
                    <div class="flex text-white mb-4 text-sm gap-1">
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span class="material-symbols-outlined" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                    </div>
                    <p class="text-[#e2e2e2] mb-6 italic leading-relaxed flex-1">"{review.text}"</p>
                    <div class="flex items-center mt-auto border-t border-white/10 pt-4">
                        <span class="text-sm font-bold uppercase tracking-widest text-brand-yellow">{review.name}</span>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
</style>

<script>
    const carousel = document.getElementById('testimonial-carousel');
    const track = document.getElementById('testimonial-track');
    let isInteracting = false;
    let scrollSpeed = 1; // Ajuste para velocidade desejada
    let lastTime = 0;

    function step(timestamp) {
        if (!carousel || !track) return;
        
        if (!isInteracting) {
            carousel.scrollLeft += scrollSpeed;
            
            // Loop infinito: se passou da metade (fim do primeiro conjunto), volta pro início
            const halfWidth = track.scrollWidth / 2;
            if (carousel.scrollLeft >= halfWidth) {
                carousel.scrollLeft -= halfWidth;
            }
        }
        requestAnimationFrame(step);
    }

    // Inicia o auto-scroll
    requestAnimationFrame(step);

    // Gestão de interatividade
    const startInteracting = () => { isInteracting = true; };
    const stopInteracting = () => { 
        // Pausa muito mais longa (30s) para permitir leitura tranquila
        setTimeout(() => { isInteracting = false; }, 30000); 
    };

    carousel.addEventListener('mousedown', startInteracting);
    carousel.addEventListener('touchstart', startInteracting, { passive: true });
    
    window.addEventListener('mouseup', stopInteracting);
    window.addEventListener('touchend', stopInteracting);

    // Prevenir bugs de arrasto no desktop
    carousel.addEventListener('mouseleave', () => { if(isInteracting) stopInteracting(); });
</script>
