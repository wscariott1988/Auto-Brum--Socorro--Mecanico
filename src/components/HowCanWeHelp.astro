        <h2 class="text-xl font-black uppercase tracking-tight mb-2 text-white">Como podemos ajudar</h2>
        <div class="h-1 w-20 bg-brand-yellow"></div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-[#1f1f1f] rounded-lg p-4 flex flex-col items-center gap-2 text-center">
            <span class="text-2xl">🚗</span>
            <span class="text-[12px] font-bold uppercase text-white tracking-wider leading-snug">Carro não liga</span>
        </div>
        <div class="bg-[#1f1f1f] rounded-lg p-4 flex flex-col items-center gap-2 text-center">
            <span class="text-2xl">🔋</span>
            <span class="text-[12px] font-bold uppercase text-white tracking-wider leading-snug">Bateria descarregada</span>
        </div>
        <div class="bg-[#1f1f1f] rounded-lg p-4 flex flex-col items-center gap-2 text-center">
            <span class="text-2xl">⛽</span>
            <span class="text-[12px] font-bold uppercase text-white tracking-wider leading-snug">Pane seca</span>
        </div>
        <div class="bg-[#1f1f1f] rounded-lg p-4 flex flex-col items-center gap-2 text-center">
            <span class="text-2xl">🌡️</span>
            <span class="text-[12px] font-bold uppercase text-white tracking-wider leading-snug">Motor superaquecido</span>
