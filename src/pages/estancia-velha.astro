---

<Layout 
    title="Rodrigo Auto Blum | Socorro Mecânico Estância Velha 24hrs"
    description={`Precisa de mecânico em ${city}? Atendimento 24h na RS-239, BR-116 e bairros. Socorro para bateria e pane mecânica com chegada em 30 min.`}
    ogTitle={`Mecânica 24h em ${city} | Rodrigo Auto Blum`}
    ogDescription={`Socorro mecânico rápido em ${city}. Atendimento na RS-239 e bairros como Bela Vista e Encosta do Sol. Reparamos no local.`}
>
	<Hero 
        cityTag={city} 
        titleLine1="Mecânico em Estância?"
        titleLine2="Socorro Rápido 24h na RS-239."
        introText={introText}
    />
	<TrustBar city={city} />
	<Services customServices={localizedServices} />
    <Testimonials />
    <FAQ city={city} />
</Layout>
