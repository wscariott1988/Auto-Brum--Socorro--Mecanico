    ctaMobile: "CHAMAR NO WHATSAPP",
    ctaDesktop: "CHAMAR NO WHATSAPP",
    waMsg: "PRECISO%20DE%20SOCORRO%20MEC%C3%82NICO%20EM%20EST%C3%82NCIA%20VELHA!%20Minha%20localiza%C3%A7%C3%A3o%20%C3%A9:"
